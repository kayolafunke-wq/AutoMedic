# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Google OAuth (from console.cloud.google.com) ─────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Firebase Admin SDK (choose ONE option) ────────────────────────────────────
# Option A: path to downloaded service account JSON
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
#
# Option B: individual env vars (CI/CD friendly)
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ── Email / SMTP ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM=AutoMedic <noreply@automedic.mw>

# ── Garage Info (used in emails) ──────────────────────────────────────────────
GARAGE_NAME=AutoMedic Garage
GARAGE_PHONE=+265 999 000 000
GARAGE_ADDRESS=Area 47, Lilongwe, Malawi
GARAGE_WHATSAPP=+265999000000
GARAGE_EMAIL=info@automedic.mw
GARAGE_HOURS=Mon–Sat: 7am – 6pm

# ── Sentry Error Tracking (optional) ──────────────────────────────────────────
# Get your DSN from sentry.io after creating a project
# Leave blank to disable error tracking
SENTRY_DSN=
